{
    "compilerOptions": {
        "allowJs": false,
        "esModuleInterop": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "paths": {
            "@/*": ["./resources/js/*"]
        },
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2022",
        "types": ["vite/client"]
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx"]
}
